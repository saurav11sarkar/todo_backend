# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=verify-full"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── Auth ─────────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10
ACCESS_TOKEN_SECRET=your-access-secret
ACCESS_TOKEN_EXPIRES=7d
REFRESH_TOKEN_SECRET=your-refresh-secret
REFRESH_TOKEN_EXPIRES=90d

# ─── Twilio (WhatsApp) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_WEBHOOK_URL=https://yourdomain.com/welcome/sms/reply

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_ADDRESS=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=
ADMIN_EMAIL=admin@example.com

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local docker-compose:  redis://redis:6379
# Cloud (Upstash, etc.): rediss://default:<password>@host:6379
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
# Used to namespace keys so dev/staging/prod never collide in the same Redis
REDIS_PREFIX=todo

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend.vercel.app
BACKEND_URL=https://your-backend.onrender.com/api/v1
